{
	"name": "Alpine",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.Go",
				"ms-vscode.hexeditor"
			],
			"settings": {
				"go.lintTool": "golangci-lint"
			}
		}
	},
	"containerEnv": {
		"CGO_ENABLED": "0"
	},
	"postCreateCommand": [
		"go",
		"mod",
		"download"
	],
	"remoteUser": "vscode"
}
