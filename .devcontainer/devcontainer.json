{
	"name": "alpine-go",
	"image": "mcr.microsoft.com/devcontainers/base:alpine",
	"features": {
		"ghcr.io/amadigan/dev-containers/go-direct:latest": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.hexeditor"
			],
			"settings": {
				"go.lintTool": "golangci-lint"
			}
		}
	},
	"containerEnv": {
		"CGO_ENABLED": "0"
	},
	"postCreateCommand": [
		"go",
		"mod",
		"download"
	],
	"remoteUser": "vscode"
}
