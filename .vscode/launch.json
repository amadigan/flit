	"version": "0.2.0",
	"configurations": [
		{
			"name": "dbwrite",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/tools/dbwrite",
			"args": [
				"${workspaceFolder}/local/db"
			]
		},
		{
			"name": "dbread",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/tools/dbread",
			"args": [
				"${workspaceFolder}/local/db"
			]
		},
		{
			"name": "artifactread",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/tools/artifactread",
			"args": [
				"${workspaceFolder}/local/uuid"
			]
		},
		{
			"name": "tree",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/tools/tree",
			"args": [
				"${workspaceFolder}/local/uuid"
			]
		},
		{
			"name": "goartifact",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/tools/goartifact",
			"args": [
				"github.com/google/uuid",
				"v1.6.0",
				"${workspaceFolder}/local/uuid"
			]
		}
	]
}
